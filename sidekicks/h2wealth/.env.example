# H2Wealth Trading Bot - Environment Configuration
# Copy this to .env and fill in your values

# ── Bybit API ──────────────────────────────────────────────
BYBIT_API_KEY=your_api_key_here
BYBIT_API_SECRET=your_api_secret_here
BYBIT_DEMO=true                    # true = demo, false = live
BYBIT_BASE_URL=https://api-demo.bybit.com   # switch to https://api.bybit.com for live

# ── Risk Management ────────────────────────────────────────
MAX_POSITION_SIZE_PCT=5.0          # max % of equity per trade
MAX_CONCURRENT_POSITIONS=5        # max open positions at once
SL_PCT=0.8                         # stop loss %
TP1_PCT=1.2                        # take profit 1 % (after fees)
TP2_PCT=2.0                        # take profit 2 %
TP3_PCT=3.5                        # take profit 3 %
TP1_CLOSE_PCT=40                   # % of position to close at TP1
TP2_CLOSE_PCT=40                   # % of position to close at TP2
TP3_CLOSE_PCT=20                   # % of position to close at TP3
LEVERAGE=5                         # default leverage
MIN_TRADE_USDT=10.0                # minimum trade size in USDT

# ── Signal Engine ──────────────────────────────────────────
SCAN_INTERVAL_SEC=60               # how often to rescan all pairs
TOP_SIGNALS_N=10                   # take top N signals
SIGNAL_EXPIRY_SEC=900              # signal TTL in seconds (15min)
SIGNAL_EXPIRE_PROFIT_TAKE_PCT=75   # close at 75% of TTL if PNL > 0

# ── Redis ──────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── Web UI ─────────────────────────────────────────────────
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8080
WEBUI_SECRET=change_this_secret   # session secret

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/h2wealth.log
