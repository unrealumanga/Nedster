{
    "project_settings": {
        "default_template": "ThirdPerson",
        "output_directory": "Projects",
        "auto_save": true,
        "auto_compile": true
    },
    "workflow_actions": {
        "create": {
            "description": "Create new UE5 project",
            "required_params": ["project_name", "template"]
        },
        "load": {
            "description": "Load existing project",
            "required_params": ["project_path"]
        },
        "run": {
            "description": "Run game",
            "required_params": ["project_path"]
        },
        "export": {
            "description": "Export assets",
            "required_params": ["project_path", "format"]
        }
    },
    "automation_settings": {
        "batch_mode": true,
        "log_level": "INFO",
        "timeout_seconds": 300
    }
}